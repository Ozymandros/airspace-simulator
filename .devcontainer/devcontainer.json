{
  "name": "Airspace Simulator",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Vite dev server",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "corepack enable && pnpm install",
  "customizations": {
    "vscode": {
      "extensions": []
    }
  },
  "remoteUser": "root"
}
