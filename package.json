{
  "name": "airspace-simulator",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && vite build --base /airspace-simulator/",
    "preview": "vite preview",
    "preview:pages": "pnpm run build:pages && vite preview --base /airspace-simulator/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "three": "^0.160.0",
    "yuka": "^0.7.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/three": "^0.160.0",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "typescript": "^5.4.5",
    "vite": "^6.4.2",
    "vitest": "^2.1.8"
  }
}
